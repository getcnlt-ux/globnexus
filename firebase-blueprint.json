{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Public and private information about a user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Consultation": {
      "title": "Consultation Inquiry",
      "description": "A formal inquiry for a specific service",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "serviceType": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "data": { "type": "object" }
      },
      "required": ["serviceType", "status", "createdAt"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "A communication channel between a user and admin",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "closed"] },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "status", "updatedAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A single message in a chat session",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "text", "createdAt"]
    },
    "Shipment": {
      "title": "Logistics Shipment",
      "description": "Tracking information for a shipment",
      "type": "object",
      "properties": {
        "trackingNumber": { "type": "string" },
        "customerName": { "type": "string" },
        "currentStep": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["trackingNumber", "currentStep", "updatedAt"]
    }
  },
  "firestore": {
    "/shipments/{shipmentId}": {
      "schema": "Shipment",
      "description": "Logistics tracking records"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/consultations/{consultationId}": {
      "schema": "Consultation",
      "description": "Service application forms"
    },
    "/chats/{chatId}": {
      "schema": "ChatSession",
      "description": "Chat sessions"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages within a session"
    }
  }
}
